# Discord Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_COMMAND_PREFIX=!

# FAP Credentials
FAP_USERNAME=your_fap_username
FAP_PASSWORD=your_fap_password

# FAP Authentication
# Run in headless mode (no GUI)
HEADLESS=true
# Auto-refresh session when expired (recommended: true)
AUTO_REFRESH=true

# Encryption
ENCRYPTION_KEY=generate_with_python_-c_from_cryptography.fernet_import_Fernet;print(Fernet.generate_key().decode())

# FlareSolverr Configuration
FLARESOLVERR_URL=http://localhost:8191/v1

# Database
DATABASE_PATH=data/fap.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/fap_bot.log

# Scheduler
SCHEDULER_TIMEZONE=Asia/Ho_Chi_Minh

# Notification Channel
DEFAULT_CHANNEL_ID=

# Check Intervals (in seconds)
ATTENDANCE_CHECK_INTERVAL=300
GRADE_CHECK_INTERVAL=3600
APPLICATION_CHECK_INTERVAL=3600
EXAM_CHECK_INTERVAL=3600
